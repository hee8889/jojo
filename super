-- =====================================================
-- PACKET FUNCTIONS
-- Note: This uses `buffer.fromstring(...)` which some exploit
-- environments provide. Keep that dependency in mind.
-- =====================================================
local function safeFireBuffer(raw)
    if typeof(buffer) == "table" and buffer.fromstring then
        pcall(function() PacketRemote:FireServer(buffer.fromstring(raw)) end)
    else
        -- fallback: try to send raw string if environment supports it
        pcall(function() PacketRemote:FireServer(raw) end)
    end
end

