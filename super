-- =====================================================
local function isAnimationPlaying(animId)
    if not character then return false end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end

    local loadedAnimations = humanoid:GetPlayingAnimationTracks()
    for _, track in ipairs(loadedAnimations) do
        local ok, anim = pcall(function() return track.Animation end)
        if ok and anim and anim.AnimationId == animId then
            return true
        end
    end
    return false
end

-- =====================================================
-- SAFE SPOT SYSTEM
-- =====================================================
local lastSafeCheck = 0

local function startSafeSpot()
    print("[SAFE SPOT] Started - radius:", SAFE_SPOT_RADIUS, "studs")

    if safeSpotConnection then
        safeSpotConnection:Disconnect()
        safeSpotConnection = nil
    end

    safeSpotConnection = RunService.Heartbeat:Connect(function()
        if not SafeSpotEnabled then return end
        if not hrp then return end

        local now = tick()
        if now - lastSafeCheck < 0.5 then return end
        lastSafeCheck = now

        local dist = (hrp.Position - SAFE_SPOT).Magnitude
        if dist > SAFE_SPOT_RADIUS then
            pcall(function()
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
                hrp.CFrame = CFrame.new(SAFE_SPOT)
            end)
            print("[SAFE SPOT] ⚡ Teleported back! (was", math.floor(dist), "studs away)")
        end
    end)
end

local function stopSafeSpot()
    if safeSpotConnection then
        safeSpotConnection:Disconnect()
        safeSpotConnection = nil
    end
    print("[SAFE SPOT] Stopped")
end

