local function getBackpackItems()
    local items = {}
    local itemsByName = {}
    local backpack = player and player:FindFirstChild("Backpack")
    if not backpack then
        warn("[AUTO SELL] Backpack not found")
        return items, itemsByName
    end
    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("StringValue") then
            local itemName = item.Name
            local idValue = item:FindFirstChild("ID")
            if idValue and idValue:IsA("StringValue") then
                local itemId = idValue.Value
                table.insert(items, { name = itemName, id = itemId })
                itemsByName[itemName] = (itemsByName[itemName] or 0) + 1
            end
        end
    end
    return items, itemsByName
end

local function getUniqueItemNames()
    local uniqueNames = {}
    local _, itemsByName = getBackpackItems()
    for itemName, count in pairs(itemsByName) do
        table.insert(uniqueNames, { name = itemName, count = count })
    end
    table.sort(uniqueNames, function(a, b) return a.name < b.name end)
    return uniqueNames
end

