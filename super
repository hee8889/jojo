local function getLootboxIds()
    local lootboxIds = {}
    local success, scrollingFrame = pcall(function()
        return player.PlayerGui and player.PlayerGui:FindFirstChild("HUD")
            and player.PlayerGui.HUD:FindFirstChild("Phone")
            and player.PlayerGui.HUD.Phone:FindFirstChild("Lootboxes")
            and player.PlayerGui.HUD.Phone.Lootboxes:FindFirstChild("ScrollingFrame")
    end)
    if not success or not scrollingFrame then
        warn("[LOOTBOX] Cannot find ScrollingFrame")
        return lootboxIds
    end
    for _, child in ipairs(scrollingFrame:GetChildren()) do
        if child:IsA("Frame") and string.find(child.Name, "-") then
            table.insert(lootboxIds, child.Name)
        end
    end
    return lootboxIds
end

-- =====================================================
