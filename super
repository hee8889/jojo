local function waitForTomatoDevil()
    local effects = Workspace.World and Workspace.World:FindFirstChild("Effects")
    if not effects then return nil end
    local waitTime = 0
    repeat
        if not CleanUpEnabled then return nil end
        local d = effects:FindFirstChild("TomatoDevil")
        if d then return d end
        task.wait(0.3)
        waitTime = waitTime + 0.3
        if waitTime > 10 then
            warn("[TOMATO] Timeout waiting for devil")
            return nil
        end
    until false
end

local function attemptTomatoOnce(quest, devil)
    if not devil or not devil.Parent then
        warn("[TOMATO] Devil not found or destroyed")
        return false
    end
    local root = devil:FindFirstChild("RootPart")
    if not root then
        warn("[TOMATO] No RootPart found")
        return false
    end
    local prompt = root:FindFirstChild("Prompt")
    if not prompt then
        warn("[TOMATO] No Prompt found")
        return false
    end

    teleportTo(root.Position + Vector3.new(0, 0, -4), 0.5)
    if not quest.Parent then
        warn("[TOMATO] Quest disappeared")
        return false
    end

    prompt.RequiresLineOfSight = false
    prompt.MaxActivationDistance = 15
    pcall(function() fireproximityprompt(prompt) end)
    task.wait(0.4)

    if isAnimationPlaying(PHASE_1_ANIM) then
        print("[PHASE 1] ✅ Animation เล่นแล้ว! เจอแล้ว!")
        teleportTo(BASE_POSITION, 1)

        print("[PHASE 1] ⏳ รอ quest value เปลี่ยน...")
        for i = 1, 30 do
            if not CleanUpEnabled then return false end
            task.wait(0.3)
            if not quest.Parent then return false end
            if quest.Value == TURNIN_QUEST_TEXT then
                print("[PHASE 1] ✅ Quest value เปลี่ยน! ไปเฟส 2")
                return true
            end
        end
        warn("[PHASE 1] ⚠️ Quest value ไม่เปลี่ยน timeout")
        return false
    else
        print("[TOMATO] ❌ Animation ไม่เล่น - ไม่ใช่ของเรา")
        teleportTo(BASE_POSITION, 1)
        return false
    end
end

local function handleTomatoQuest(quest)
    local devil = waitForTomatoDevil()
    if devil and CleanUpEnabled then
        if attemptTomatoOnce(quest, devil) then return end
    end

    print("[TOMATO] Using fallback positions...")
    for _, pos in ipairs(TOMATO_FALLBACK_POSITIONS) do
        if not CleanUpEnabled then break end
        print("[TOMATO] Trying fallback position:", pos)
        teleportTo(pos, 1.2)
        task.wait(0.5)
        local nearbyDevil = Workspace.World and Workspace.World:FindFirstChild("Effects") and Workspace.World.Effects:FindFirstChild("TomatoDevil")
        if nearbyDevil then
            print("[TOMATO] Found devil at fallback position")
            local root = nearbyDevil:FindFirstChild("RootPart")
            if root then
                local prompt = root:FindFirstChild("Prompt")
                if prompt then
                    teleportTo(root.Position + Vector3.new(0, 0, -4), 0.5)
                    if quest.Parent then
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = 15
                        pcall(function() fireproximityprompt(prompt) end)
                        task.wait(0.4)

                        if isAnimationPlaying(PHASE_1_ANIM) then
                            print("[PHASE 1] ✅ Animation เล่นแล้ว! เจอแล้ว!")
                            teleportTo(BASE_POSITION, 1)
                            print("[PHASE 1] ⏳ รอ quest value เปลี่ยน...")
                            for i = 1, 30 do
                                if not CleanUpEnabled then break end
                                task.wait(0.3)
                                if not quest.Parent then break end
                                if quest.Value == TURNIN_QUEST_TEXT then
                                    print("[PHASE 1] ✅ Quest value เปลี่ยน! Success at fallback position!")
                                    return
                                end
                            end
                        else
                            print("[TOMATO] ❌ Animation ไม่เล่น - ไม่ใช่ของเรา")
                        end
                    end
                end
            end
        else
            print("[TOMATO] No devil at this position")
        end
    end

    warn("[TOMATO] All attempts failed, waiting for next devil...")
    teleportTo(BASE_POSITION, 1)
    task.wait(2)
end

local function attemptTurnInOnce(quest)
    for _, areaName in ipairs(AREAS) do
        if not CleanUpEnabled then return false end
        local area = turnInRoot and turnInRoot:FindFirstChild(areaName)
        if area then
            local t = area:FindFirstChild("TurnIn")
            if t then
                local prompt = t:FindFirstChild("Prompt")
                local part = t:IsA("BasePart") and t or t:FindFirstChildWhichIsA("BasePart")
                if prompt and part then
                    teleportTo(part.Position + Vector3.new(0, 0, -4), 0.4)
                    prompt.RequiresLineOfSight = false
                    prompt.MaxActivationDistance = 15
                    pcall(function() fireproximityprompt(prompt) end)
                    task.wait(0.4)

                    if isAnimationPlaying(PHASE_2_ANIM) then
                        print("[PHASE 2] ✅ Animation เล่นแล้ว! เจอแล้ว!")
                        teleportTo(BASE_POSITION, 0.8)

                        print("[PHASE 2] ⏳ รอ animation phase 2 จบ...")
                        for i = 1, 60 do
                            if not CleanUpEnabled then return false end
                            task.wait(0.1)
                            if not isAnimationPlaying(PHASE_2_ANIM) then
                                print("[PHASE 2] ✅ Animation จบ! Mission สำเร็จ!")
                                return true
                            end
                        end
                        print("[PHASE 2] ⚠️ Animation timeout")
                        return true
                    else
                        print("[TURN IN] ❌ Animation ไม่เล่น - ไม่ใช่ของเรา ลองพื้นที่ถัดไป:", areaName)
                    end
                end
            end
        end
    end
    return false
end

