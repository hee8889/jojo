local function startAutoSell()
    print("[AUTO SELL] 🚀 Started (GROUP PARALLEL MODE)")

    while AutoSellEnabled and Wait() do
        local success, err = pcall(function()
            task.wait(0.1)

            local hasSelection = false
            for _, isSelected in pairs(SelectedItemsToSell) do
                if isSelected then hasSelection = true break end
            end

            if not hasSelection then
                print("[AUTO SELL] ⚠️ No items selected!")
                task.wait(2)
                return
            end

            local items, _ = getBackpackItems()
            if #items == 0 then
                task.wait(1)
                return
            end

            local grouped = {}
            for _, itemData in ipairs(items) do
                local name = itemData.name
                if SelectedItemsToSell[name] then
                    if not grouped[name] then grouped[name] = {} end
                    table.insert(grouped[name], itemData.id)
                end
            end

            local groupCount = 0
            for _ in pairs(grouped) do groupCount = groupCount + 1 end
            print("[AUTO SELL] 📦 Selling", groupCount, "item types in parallel!")

            local totalSold = 0

            for itemName, ids in pairs(grouped) do
                if not AutoSellEnabled then break end
                task.spawn(function()
                    local sold = 0
                    for _, itemId in ipairs(ids) do
                        if not AutoSellEnabled then break end
                        pcall(function()
                            pawnshopSelect(itemId, itemName)
                            task.wait(0.3)
                            pawnshopSell()
                        end)
                        sold = sold + 1
                        task.wait(0.05)
                    end
                    print("[AUTO SELL] ✅", itemName, "sold", sold .. "/" .. #ids)
                    totalSold = totalSold + sold
                end)
            end

            task.wait(2)
            print("[AUTO SELL] ⚡ Total sold:", totalSold, "items!")
            task.wait(0.5)
        end)

        if not success then
            warn("[AUTO SELL] ❌ Error:", err)
            task.wait(1)
        end
    end

    print("[AUTO SELL] 🛑 Stopped")
end

-- =====================================================
-- MAIN FARMING LOOP (ANIMATION-BASED)
-- =====================================================
local function startFarming()
    print("[AUTO FARM] CleanUp Started (ANIMATION-BASED)")

    while CleanUpEnabled and Wait() do
        local success, err = pcall(function()
            randomWait(0.3, 0.5)
            local quest = getCurrentQuest()

            if not quest then
                teleportTo(BASE_POSITION, 1)
                local selectedCount = 0
                for _, isSelected in pairs(SelectedCleanUpMissions) do
                    if isSelected then selectedCount = selectedCount + 1 end
                end

                if selectedCount == 0 then
                    print("[CLEANUP] No missions selected, trying all...")
                    for _, folder in ipairs(inactiveFolder:GetChildren()) do
                        if not CleanUpEnabled then break end
                        if folder:IsA("Folder") then
                            engageCleanupMission(folder.Name)
                            task.wait(0.5)
                            if getCurrentQuest() then break end
                        end
                    end
                else
                    local targetMissions = {}
                    for _, folder in ipairs(inactiveFolder:GetChildren()) do
                        if SelectedCleanUpMissions[folder.Name] then
                            table.insert(targetMissions, folder)
                        end
                    end
                    for i = #targetMissions, 1, -1 do
                        local j = math.random(i)
                        targetMissions[i], targetMissions[j] = targetMissions[j], targetMissions[i]
                    end
                    for _, folder in ipairs(targetMissions) do
                        if not CleanUpEnabled then break end
                        engageCleanupMission(folder.Name)
                        task.wait(0.5)
                        if getCurrentQuest() then break end
                    end
                end
                return
            end

            if quest.Value == TARGET_QUEST_TEXT then
                print("[CLEANUP] 🎬 เฟส 1: หา Tomato Devil...")
                handleTomatoQuest(quest)
                return
            end

            if quest.Value == TURNIN_QUEST_TEXT then
                print("[CLEANUP] 🎬 เฟส 2: ไป Turn-in Point...")
                local ok = attemptTurnInOnce(quest)
                if not ok and getCurrentQuest() and CleanUpEnabled then
                    print("[CLEANUP] ⏳ ลองตำแหน่ง fallback...")
                    for _, pos in ipairs(FALLBACK_POSITIONS) do
                        if not CleanUpEnabled then break end
                        teleportTo(pos, 1.2)
                        if attemptTurnInOnce(quest) then break end
                    end
                end
            end
        end)

        if not success then
            warn("[AUTO FARM] Error:", err)
            task.wait(2)
        end
    end

    print("[AUTO FARM] CleanUp Stopped")
end

-- =====================================================
-- AUTO INVADE LOOP
-- =====================================================
local function startInvade()
    print("[AUTO INVADE] Started")

    while InvadeEnabled and Wait() do
        local success, err = pcall(function()
            randomWait(0.5, 1)
            local quest = getCurrentQuest()

            if quest and quest.Value == INVADE_QUEST_TEXT then
                print("[AUTO INVADE] Already have quest, waiting...")
                local waitCount = 0
                while InvadeEnabled and quest.Parent and quest.Value == INVADE_QUEST_TEXT and waitCount < 60 do
                    task.wait(1)
                    waitCount = waitCount + 1
                    quest = getCurrentQuest()
                    if not quest then break end
                end
                if waitCount >= 60 then
                    warn("[AUTO INVADE] Quest stuck, resetting...")
                end
                task.wait(1)
                return
            end

            teleportTo(BASE_POSITION, 1)
            local selectedCount = 0
            for _, isSelected in pairs(SelectedInvadeMissions) do
                if isSelected then selectedCount = selectedCount + 1 end
            end
            if selectedCount == 0 then
                print("[AUTO INVADE] No missions selected!")
                task.wait(3)
                return
            end

            local activeMissions = activeFolder:GetChildren()
            if #activeMissions == 0 then task.wait(3) return end
            local targetMissions = {}
            for _, folder in ipairs(activeMissions) do
                if SelectedInvadeMissions[folder.Name] then
                    table.insert(targetMissions, folder)
                end
            end
            if #targetMissions == 0 then task.wait(3) return end
            for i = #targetMissions, 1, -1 do
                local j = math.random(i)
                targetMissions[i], targetMissions[j] = targetMissions[j], targetMissions[i]
            end
            for _, folder in ipairs(targetMissions) do
                if not InvadeEnabled then break end
                pcall(function() interceptMission(folder.Name) end)
                randomWait(0.5, 1)
                local currentQuest = getCurrentQuest()
                if currentQuest and currentQuest.Value == INVADE_QUEST_TEXT then
                    print("[AUTO INVADE] Got quest!")
                    task.wait(0.3)
                    teleportTo(BASE_POSITION, 1)
                    break
                end
            end
        end)

        if not success then
            warn("[AUTO INVADE] Error:", err)
            task.wait(3)
        end
    end

    print("[AUTO INVADE] Stopped")
end

-- =====================================================
-- AUTO LOOTBOX LOOP
-- =====================================================
local function startLootbox()
    print("[AUTO LOOTBOX] Started")

    while LootboxEnabled and Wait() do
        local success, err = pcall(function()
            randomWait(0.5, 1)
            local lootboxIds = getLootboxIds()

            if #lootboxIds == 0 then
                print("[AUTO LOOTBOX] No lootboxes found, waiting...")
                task.wait(3)
                return
            end

            print("[AUTO LOOTBOX] Found", #lootboxIds, "lootboxes")

            for _, lootboxId in ipairs(lootboxIds) do
                if not LootboxEnabled then break end
                print("[AUTO LOOTBOX] Opening:", lootboxId:sub(1, 8) .. "...")

                pcall(function() openLootbox(lootboxId) end)
                task.wait(2.5)

                local itemNames = {}
                for attempt = 1, 5 do
                    local uiOk, lootboxList = pcall(function()
                        return player.PlayerGui and player.PlayerGui:FindFirstChild("OnScreenEffects")
                            and player.PlayerGui.OnScreenEffects:FindFirstChild("Lootbox")
                            and player.PlayerGui.OnScreenEffects.Lootbox:FindFirstChild("List")
                    end)
                    if uiOk and lootboxList then
                        for _, child in ipairs(lootboxList:GetChildren()) do
                            local itemName = child.Name
                            if not itemName:match("^UI") and
                               not itemName:match("^_") and
                               itemName ~= "" and
                               #itemName > 2 then
                                table.insert(itemNames, itemName)
                            end
                        end
                    end
                    if #itemNames > 0 then
                        print("[AUTO LOOTBOX] Got", #itemNames, "items from UI (attempt", attempt .. ")")
                        break
                    end
                    print("[AUTO LOOTBOX] UI empty, retrying... (" .. attempt .. "/5)")
                    task.wait(0.5)
                end

                if #itemNames > 0 then
                    for _, itemName in ipairs(itemNames) do
                        if not LootboxEnabled then break end
                        pcall(function() takeItem(itemName) end)
                        print("[AUTO LOOTBOX] ✅ Took:", itemName)
                        task.wait(0.3)
                    end
                else
                    warn("[AUTO LOOTBOX] ⚠️ Could not read item list!")
                end

                task.wait(1)
            end

            task.wait(5)
        end)

        if not success then
            warn("[AUTO LOOTBOX] Error:", err)
            task.wait(3)
        end
    end

    print("[AUTO LOOTBOX] Stopped")
end

