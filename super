local function getMissionDisplayName(folder)
    local directive = folder:FindFirstChild("Directive")
    local directiveName = directive and directive.Value or "Unknown"
    local shortId = folder.Name:sub(1, 8)
    return directiveName .. " [" .. shortId .. "]"
end

-- =====================================================
-- CLEANUP MISSION SELECTOR
-- =====================================================
local CleanUpSection = GeneralTab:CreateSection({
    Name = "CleanUp Mission Selector"
})

local function scanCleanUpMissions()
    for _, toggle in pairs(CleanUpMissionToggles) do
        if toggle and toggle.Remove then
            pcall(function() toggle:Remove() end)
        end
    end
    CleanUpMissionToggles = {}
    SelectedCleanUpMissions = {}

    print("[CLEANUP SCAN] Scanning Inactive folder...")
    local allMissions = {}
    for _, folder in ipairs(inactiveFolder:GetChildren()) do
        if folder:IsA("Folder") then
            local directive = folder:FindFirstChild("Directive")
            local directiveValue = directive and directive.Value or "NO_DIRECTIVE"
            table.insert(allMissions, { folder = folder, id = folder.Name, directive = directiveValue })
        end
    end
    if #allMissions == 0 then
        print("[CLEANUP SCAN] ⚠️ No missions found in Inactive folder!")
        return
    end
    for _, missionData in ipairs(allMissions) do
        local folder = missionData.folder
        local missionId = missionData.id
        local directiveValue = missionData.directive
        local displayName = getMissionDisplayName(folder)
        local fullName = displayName .. " (" .. directiveValue .. ")"
        local toggle = CleanUpSection:AddToggle({
            Name = fullName,
            Flag = "CleanUpMission_" .. missionId,
            Callback = function(value)
                SelectedCleanUpMissions[missionId] = value
                if value then
                    print("[CLEANUP SELECT] Selected:", displayName)
                else
                    print("[CLEANUP SELECT] Deselected:", displayName)
                end
            end
        })
        CleanUpMissionToggles[missionId] = toggle
    end
    print("[CLEANUP SCAN] Created", #allMissions, "toggles")
end

